{
  "mcpServers": {
    "finance-mcp": {
      "command": ".venv/bin/python",
      "args": [".agents/mcp/finance/server.py"],
      "env": {
        "PROJECT_ROOT": "."
      }
    },
    "wiki-mcp": {
      "command": ".venv/bin/python",
      "args": [".agents/mcp/wiki/server.py"],
      "env": {
        "PROJECT_ROOT": "."
      }
    },
    "research-mcp": {
      "command": ".venv/bin/python",
      "args": [".agents/mcp/research/server.py"],
      "env": {
        "PROJECT_ROOT": ".",
        "SEMANTIC_SCHOLAR_API_KEY": "REDACTED"
      }
    },
    "menumaker": {
      "command": "../menumaker-mcp/.venv/bin/python",
      "args": [
        "-m",
        "menumaker.server"
      ],
      "env": {
        "MENUMAKER_DATA_DIR": "../menumaker-mcp/.agents/mcp/data"
      }
    }
  }
}
