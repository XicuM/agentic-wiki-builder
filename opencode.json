{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "finance-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/finance/server.py"
      ],
      "environment": {}
    },
    "wiki-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/wiki/server.py"
      ],
      "environment": {}
    },
    "research-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/research/server.py"
      ],
      "environment": {
        "SEMANTIC_SCHOLAR_API_KEY": ""
      }
    },
    "menumaker": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/menumaker/server.py"
      ],
      "environment": {
        "MENUMAKER_DATA_DIR": "/home/user/Projects/agentic-wiki-builder/.agents/mcp/menumaker/data"
      }
    }
  }
}
