{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "finance-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/finance/server.py"
      ],
      "environment": {},
      "enabled": true
    },
    "wiki-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/wiki/server.py"
      ],
      "environment": {},
      "enabled": true
    },
    "research-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/research/server.py"
      ],
      "environment": {
        "SEMANTIC_SCHOLAR_API_KEY": ""
      },
      "enabled": true
    },
    "google-drive-mcp": {
      "type": "local",
      "command": [
        ".venv/bin/python",
        ".agents/mcp/gdrive/server.py"
      ],
      "environment": {},
      "enabled": true
    }
  }
}
